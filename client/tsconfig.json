{
  "compilerOptions": {
    "target": "es2015",
    "lib": ["dom", "dom.iterable", "esnext"],
    "moduleDetection": "force",
    "module": "esnext", // Use "esnext" instead of "Preserve" for better compatibility with ESM
    "moduleResolution": "node", // Updated to "node" "resolveJsonModule": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx", // Use "react-jsx" to leverage the new JSX transform in React 17+
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@": ["src"],
      "@lib/*": ["src/lib/*"],
      "@game/*": ["src/features/gameplay/*"],
      "@game-access/*": ["src/features/game-access/*"],
      "@pages/*": ["src/pages/*"],
      "@style/*": ["src/style/*"],
      "@shared-types/*": ["src/shared-types/*"],
      "@test/*": ["test/*"],
      "src/*": ["./src/*"]
    }
  },
  "include": ["src", "test"], // Ensure both src and test directories are included
  "exclude": ["node_modules", "dist"]
}
