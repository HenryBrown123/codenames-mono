{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@backend/*": ["src/*"],
      "@backend/test/*": ["test/*"]
    }
  },
  "include": ["test/**/*", "src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "src/zzz-legacy/**"],
  "references": [{ "path": "../shared" }]
}
