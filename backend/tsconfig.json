{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@backend/test/*": ["test/*"],
      "@backend/common/*": ["src/common/*"],
      "@backend/gameplay/*": ["src/gameplay/*"],
      "@backend/ai/*": ["src/ai/*"]
    }
  },
  "include": ["test/**/*", "src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "src/zzz-legacy/**"],
  "references": [{ "path": "../shared" }]
}
